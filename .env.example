# Flask Settings
SECRET_KEY=generate-a-secure-random-key-here
FLASK_APP=run.py
FLASK_DEBUG=1

# Firebase Settings
# Option 1: Path to your service account JSON file
FIREBASE_SERVICE_ACCOUNT_JSON=path/to/your/firebase-credentials.json
# Option 2: Database URL (optional, depends on your Firebase setup)
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com

# Gmail Settings
MAIL_USERNAME=YOUR_GMAIL.com
MAIL_PASSWORD=YOUR_APP_PASSWORD
MAIL_DEFAULT_SENDER=YOUR_GMAIL.COM

# Google OAuth Settings
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET

